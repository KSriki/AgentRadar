# .env.example — copy to .env and fill in real values.
# .env is gitignored; .env.example is committed.

# ---------------------------------------------------------------------------
# Database connections (defaults match docker-compose.yml)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentradar_dev

POSTGRES_DSN=postgresql://agentradar:agentradar_dev@localhost:5432/agentradar

# ---------------------------------------------------------------------------
# Object storage (MinIO locally; real S3 in prod)
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=agentradar
S3_SECRET_KEY=agentradar_dev
S3_BUCKET=agentradar-artifacts
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# AWS Bedrock (for Claude). Use AWS profile or explicit creds.
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_CRITIC_MODEL_ID=anthropic.claude-opus-4-20250514-v1:0

# ---------------------------------------------------------------------------
# Embeddings — Bedrock Titan or local; choose one.
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=bedrock
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIM=1024

# ---------------------------------------------------------------------------
# Observability (optional during early dev)
# ---------------------------------------------------------------------------
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=agentradar-dev
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=local